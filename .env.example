# Supabase (proyecto propio e independiente de cualquier otro proyecto existente)
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Sesion de administrador (cookie firmada). Genera un valor largo y aleatorio, p.ej.:
#   openssl rand -base64 48
SESSION_SECRET=

# LLM de copy via OpenRouter (https://openrouter.ai)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-sonnet-4.5

# Generacion de imagenes via Gemini 2.5 Flash Image ("Nano Banana").
# Conseguila gratis en https://aistudio.google.com/apikey
GEMINI_API_KEY=
